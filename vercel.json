{
  "version": 2,
  "buildCommand": "npm run build --prefix shopsphere-react",
  "installCommand": "npm install --prefix shopsphere && npm install --prefix shopsphere-react",
  "outputDirectory": "shopsphere-react/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/shopsphere/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
