# MongoDB Database Configuration
MONGO_URI=mongodb://127.0.0.1:27017/shopsphere

# Session secret (change this to a long random string in production)
SESSION_SECRET=change_this_to_a_long_random_secret_string

# Server port
PORT=3000

# Google OAuth — get these from https://console.cloud.google.com/apis/credentials
# Leave blank/commented out and the "Continue with Google" button will simply not work
# (the rest of the site is unaffected).
# GOOGLE_CLIENT_ID=your_google_client_id_here
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Facebook OAuth — get these from https://developers.facebook.com/apps
# Leave blank/commented out and the "Continue with Facebook" button will simply not work.
# FACEBOOK_APP_ID=your_facebook_app_id_here
# FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# Razorpay (test mode) — get these from https://dashboard.razorpay.com/app/keys
# Test mode keys start with "rzp_test_". Without these set, checkout will show
# an error instead of opening the payment popup; the rest of the site still works.
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here


# Twilio (SMS OTP) — get these from https://console.twilio.com
# TWILIO_PHONE_NUMBER must be a number Twilio gave you (trial accounts get one
# free number). Without these set, OTP requests will fail with a clear error
# instead of crashing the server.
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
